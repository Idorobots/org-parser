                          bullet='-',
                          first_line=RichText('This item begins after the two blank lines that ended the previous item.'),
                          body=[
                              Paragraph(body=RichText('Two consecutive blank lines terminate the list item above.\n')),
                            ],
                        ),
                      ],
                  ),
                  BlankLine(),
                  List(
                    items=[
                        ListItem(bullet='-', first_line=RichText('Final item in the list.')),
                      ],
                  ),
                ],
            ),
          ],
      ),
    ],
)