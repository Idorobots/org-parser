                        ListItem(bullet='.', ordered_counter='c', first_line=RichText('Match weight: delicate dishes with delicate wines.')),
                        ListItem(bullet='.', ordered_counter='d', first_line=RichText('Bridge flavours: acidic wines with acidic dishes.')),
