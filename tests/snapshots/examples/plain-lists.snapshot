                  BlankLine(),
                  List(
                    items=[
                        ListItem(bullet='.', ordered_counter='1', first_line=RichText('Combine 120 ml dry white wine and 60 ml white wine vinegar in a small saucepan.')),
                        ListItem(bullet='.', ordered_counter='2', first_line=RichText('Add two finely minced shallots and a pinch of white pepper.')),
                        ListItem(bullet='.', ordered_counter='3', first_line=RichText('Reduce over medium heat until only 2 tablespoons of liquid remain.')),
                        ListItem(bullet='.', ordered_counter='4', first_line=RichText('Remove from heat and let cool to approximately 60°C.')),
                        ListItem(bullet='.', ordered_counter='5', first_line=RichText('Add 250 g cold unsalted butter, one cube at a time, whisking constantly.')),
                        ListItem(bullet='.', ordered_counter='6', first_line=RichText('Return briefly to very low heat if the emulsion cools too much.')),
                        ListItem(bullet='.', ordered_counter='7', first_line=RichText('Strain through a fine sieve and season with salt and lemon juice.')),
                        ListItem(bullet='.', ordered_counter='8', first_line=RichText('Keep warm in a bain-marie at 55°C until service.')),
                      ],
                  ),
                  BlankLine(),
                ],
            ),
            Heading(
