                        ListItem(bullet=')', ordered_counter='1', first_line=RichText('Soak the 1000-grit stone in water for ten minutes.')),
                        ListItem(bullet=')', ordered_counter='2', first_line=RichText('Hold the blade at a consistent 15–20° angle to the stone.')),
                        ListItem(bullet=')', ordered_counter='3', first_line=RichText('Push the edge forward in smooth arcs, heel to tip, ten strokes per side.')),
                        ListItem(bullet=')', ordered_counter='4', first_line=RichText('Move to the 3000-grit stone and repeat with lighter pressure.')),
                        ListItem(bullet=')', ordered_counter='5', first_line=RichText('Finish on the 6000-grit stone with minimal pressure, eight strokes per side.')),
                        ListItem(bullet=')', ordered_counter='6', first_line=RichText('Strop on leather five times per side.')),
                        ListItem(bullet=')', ordered_counter='7', first_line=RichText('Test sharpness by slicing a sheet of paper cleanly.')),
