Document(
  filename='examples/large.org',
  title=RichText('Vantage — Distributed In-Memory Cache'),
  author=RichText('The Vantage Maintainers'),
  category=RichText('vantage'),
  description=RichText('Engineering wiki and project reference for the Vantage distributed in-memory cache system.'),
  todo=RichText('TODO IN-PROGRESS BLOCKED REVIEW | DONE CANCELLED WONTFIX'),
  keywords=[
      Keyword(key='EMAIL', value=RichText('maintainers@vantage.example.dev')),
      Keyword(key='DATE', value=RichText('<2025-01-06 Mon>')),
      Keyword(key='LANGUAGE', value=RichText('en')),
      Keyword(key='FILETAGS', value=RichText(':vantage:engineering:')),
      Keyword(key='STARTUP', value=RichText('overview')),
      Keyword(key='PROPERTY', value=RichText('effort_default 1:00')),
      Keyword(key='OPTIONS', value=RichText('toc:2')),
    ],
  properties={
      'project_url': RichText('https://github.com/example/vantage'),
      'license': RichText('Apache-2.0'),
      'language': RichText('Rust'),
      'min_rust': RichText('1.75.0'),
    },
  body=[
      BlankLine(),
      Comment(text='This file is the canonical engineering reference for the Vantage project.'),
      Comment(text='All architecture decisions, API contracts, and operational procedures are'),
      Comment(text='tracked here. For user documentation see docs/user-guide/.'),
      BlankLine(),
      BlankLine(),
      Paragraph(body=RichText('Vantage is a *distributed in-memory cache* designed for sub-millisecond read\nlatency at high concurrency. It implements a superset of the <<<Redis>>> wire\nprotocol and exposes both a binary framing protocol and a human-readable\ntext interface.\n')),
      BlankLine(),
      Paragraph(body=RichText('Key properties of Vantage:\n')),
      BlankLine(),
      List(
        items=[
            ListItem(bullet='-', first_line=RichText('*Consistent hashing* with virtual nodes for cluster topology.')),
            ListItem(bullet='-', first_line=RichText('*Multi-master replication* with last-write-wins conflict resolution.')),
            ListItem(bullet='-', first_line=RichText('*Pluggable eviction policies*: LRU, LFU, TTL-only, CLOCK.')),
            ListItem(bullet='-', first_line=RichText('*Persistence* via append-only log with configurable fsync intervals.')),
            ListItem(bullet='-', first_line=RichText('*TLS mutual authentication* on all inter-node and client connections.')),
          ],
      ),
      BlankLine(),
      HorizontalRule(rule='-----'),
      BlankLine(),
    ],
  children=[
      Heading(
        level=1,
        title=RichText('Project Overview'),
        properties={
            'CUSTOM_ID': RichText('project-overview'),
          },
        body=[
            BlankLine(),
          ],
        children=[
            Heading(
              level=2,
              title=RichText('Vision and Goals'),
              properties={
                  'CUSTOM_ID': RichText('vision'),
                },
              body=[
                  BlankLine(),
                  Paragraph(body=RichText('Vantage exists to fill the gap between Redis (single-master, complex cluster\nsharding) and Memcached (no replication, limited data types). Our goals:\n')),
                  BlankLine(),
                  List(
                    items=[
                        ListItem(bullet='.', ordered_counter='1', first_line=RichText('Drop-in Redis protocol compatibility for the most common commands.')),
                        ListItem(bullet='.', ordered_counter='2', first_line=RichText('Horizontal write scalability without a primary/replica split.')),
                        ListItem(bullet='.', ordered_counter='3', first_line=RichText('First-class Rust client with async/await support.')),
                        ListItem(bullet='.', ordered_counter='4', first_line=RichText('Observable by default: OpenTelemetry traces and Prometheus metrics out of the box.')),
                      ],
                  ),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Non-Goals'),
              body=[
                  Paragraph(body=RichText('We explicitly do *not* aim to:\n')),
                  BlankLine(),
                  List(
                    items=[
                        ListItem(bullet='-', first_line=RichText('Replace Redis as a pub/sub broker or stream processor.')),
                        ListItem(bullet='-', first_line=RichText('Provide ACID transactional guarantees.')),
                        ListItem(bullet='-', first_line=RichText('Support arbitrary Lua scripting (=EVAL= is a non-goal for v1).')),
                        ListItem(bullet='-', first_line=RichText('Offer a managed cloud service (that is a downstream concern).')),
                      ],
                  ),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Licence and Governance'),
              properties={
                  'CUSTOM_ID': RichText('governance'),
                },
              body=[
                  Paragraph(body=RichText('Vantage is released under the *Apache License 2.0*. Governance follows the\n/Benevolent Dictator For Life/ (BDFL) model until the project reaches 1.0,\nat which point a steering committee of five maintainers will be constituted.\n')),
                  BlankLine(),
                  Paragraph(body=RichText('See [[file:GOVERNANCE.md]] for the full governance document.\n')),
                  BlankLine(),
                  HorizontalRule(rule='-----'),
                  BlankLine(),
                ],
            ),
          ],
      ),
      Heading(
        level=1,
        title=RichText('Architecture'),
        properties={
            'CUSTOM_ID': RichText('architecture'),
          },
        body=[
            BlankLine(),
          ],
        children=[
            Heading(
              level=2,
              title=RichText('System Components'),
              properties={
                  'CUSTOM_ID': RichText('components'),
                },
              body=[
                  BlankLine(),
                  Paragraph(body=RichText('The Vantage system comprises five major components:\n')),
                  BlankLine(),
                  Table(
                    rows=[
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' Component         ')),
                              TableCell(value=RichText(' Language ')),
                              TableCell(value=RichText(' Role                                         ')),
                            ],
                        ),
                        TableRuleRow(raw='|-------------------+----------+----------------------------------------------|'),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' ~vantage-server~  ')),
                              TableCell(value=RichText(' Rust     ')),
                              TableCell(value=RichText(' Core cache daemon, protocol handler          ')),
                            ],
                        ),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' ~vantage-cluster~ ')),
                              TableCell(value=RichText(' Rust     ')),
                              TableCell(value=RichText(' Cluster membership, gossip, topology         ')),
                            ],
                        ),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' ~vantage-client~  ')),
                              TableCell(value=RichText(' Rust     ')),
                              TableCell(value=RichText(' Async client library (Tokio)                 ')),
                            ],
                        ),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' ~vantage-cli~     ')),
                              TableCell(value=RichText(' Rust     ')),
                              TableCell(value=RichText(' Interactive REPL and scripting tool          ')),
                            ],
                        ),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' ~vantage-exporter~')),
                              TableCell(value=RichText(' Go       ')),
                              TableCell(value=RichText(' Prometheus metrics bridge (sidecar)          ')),
                            ],
                        ),
                      ],
                  ),
                  BlankLine(),
                ],
              children=[
                  Heading(
                    level=3,
                    title=RichText('vantage-server'),
                    properties={
                        'CUSTOM_ID': RichText('vantage-server'),
                      },
                    body=[
                        BlankLine(),
                        Paragraph(body=RichText('The server process owns the in-memory keyspace and handles all client\nconnections. It is structured as a tower of async middleware layers:\n')),
                        BlankLine(),
                        ExampleBlock(body='TLS termination\n    ↓\nProtocol framing (Redis RESP3 / Vantage binary)\n    ↓\nCommand dispatch\n    ↓\nACL enforcement\n    ↓\nKeyspace mutation / read\n    ↓\nReplication fanout\n    ↓\nResponse serialisation\n'),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('vantage-cluster'),
                    properties={
                        'CUSTOM_ID': RichText('vantage-cluster'),
                      },
                    body=[
                        Paragraph(body=RichText('Cluster membership uses a variant of the SWIM[fn:swim] gossip protocol with\nthe following modifications:\n')),
                        BlankLine(),
                        List(
                          items=[
                              ListItem(bullet='-', first_line=RichText('Piggyback propagation of keyspace metadata (not just membership events).')),
                              ListItem(bullet='-', first_line=RichText('Suspicion sub-protocol suppressed in favour of direct failure detection.')),
                              ListItem(bullet='-', first_line=RichText('Ring topology exposed as a =RwLock<Arc<Ring>>= for zero-copy reads.')),
                            ],
                        ),
                        BlankLine(),
                        Paragraph(body=RichText('[fn:swim] Das, A., Gupta, I., & Motivala, A. (2002). SWIM: Scalable weakly-consistent\ninfection-style process group membership protocol. /DSN 2002/.\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('vantage-client'),
                    properties={
                        'CUSTOM_ID': RichText('vantage-client'),
                      },
                    body=[
                        Paragraph(body=RichText('The async client uses connection pooling with configurable:\n')),
                        BlankLine(),
                        List(
                          items=[
                              ListItem(bullet='-', first_line=RichText('Minimum idle connections per node.')),
                              ListItem(bullet='-', first_line=RichText('Maximum connections per node.')),
                              ListItem(bullet='-', first_line=RichText('Connection acquisition timeout.')),
                              ListItem(bullet='-', first_line=RichText('Health check interval.')),
                            ],
                        ),
                        BlankLine(),
                        SourceBlock(language='rust', body='use vantage_client::{Client, Config};\n\n#[tokio::main]\nasync fn main() -> anyhow::Result<()> {\n    let config = Config::builder()\n        .nodes(["cache-1:6380", "cache-2:6380", "cache-3:6380"])\n        .tls_ca_cert("ca.crt")\n        .pool_size(32)\n        .build()?;\n\n    let client = Client::connect(config).await?;\n    client.set("hello", "world", None).await?;\n    let val: Option<String> = client.get("hello").await?;\n    println!("{val:?}");  // Some("world")\n    Ok(())\n}\n'),
                        BlankLine(),
                      ],
                  ),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Data Flow'),
              properties={
                  'CUSTOM_ID': RichText('data-flow'),
                },
              body=[
                  BlankLine(),
                ],
              children=[
                  Heading(
                    level=3,
                    title=RichText('Write path'),
                    body=[
                        BlankLine(),
                        Paragraph(body=RichText('A write request follows this path through the system:\n')),
                        BlankLine(),
                        List(
                          items=[
                              ListItem(bullet='.', ordered_counter='1', first_line=RichText('Client sends =SET key value [EX seconds]= in RESP3 format.')),
                              ListItem(bullet='.', ordered_counter='2', first_line=RichText('Server decodes the command and performs ACL check.')),
                              ListItem(bullet='.', ordered_counter='3', first_line=RichText('Consistent hash ring determines which /primary shard/ owns the key.')),
                              ListItem(bullet='.', ordered_counter='4', first_line=RichText('If the server is *not* the primary shard, the request is *proxied*.')),
                              ListItem(bullet='.', ordered_counter='5', first_line=RichText('Primary shard acquires a shard lock (=tokio::sync::RwLock=, write mode).')),
                              ListItem(bullet='.', ordered_counter='6', first_line=RichText('Value is written to the in-memory slab allocator.')),
                              ListItem(bullet='.', ordered_counter='7', first_line=RichText('Write is appended to the AOF (append-only file) if persistence is enabled.')),
                              ListItem(bullet='.', ordered_counter='8', first_line=RichText('Replication events are fanned out to replicas asynchronously.')),
                              ListItem(bullet='.', ordered_counter='9', first_line=RichText('=+OK= response is returned to the client.')),
                            ],
                        ),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('Read path'),
                    body=[
                        List(
                          items=[
                              ListItem(bullet='.', ordered_counter='1', first_line=RichText('Client sends =GET key=.')),
                              ListItem(bullet='.', ordered_counter='2', first_line=RichText('ACL check.')),
                              ListItem(bullet='.', ordered_counter='3', first_line=RichText('Consistent hash: locate primary shard.')),
                              ListItem(bullet='.', ordered_counter='4', first_line=RichText('Proxy if not local (or read from any replica if =read_replicas= is enabled).')),
                              ListItem(bullet='.', ordered_counter='5', first_line=RichText('Acquire shard lock (read mode).')),
                              ListItem(bullet='.', ordered_counter='6', first_line=RichText('Lookup in the slab, check TTL expiry.')),
                              ListItem(bullet='.', ordered_counter='7', first_line=RichText('Return value or =$-1= (nil bulk string).')),
                            ],
                        ),
                        BlankLine(),
                      ],
                  ),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Consistent Hashing'),
              properties={
                  'CUSTOM_ID': RichText('consistent-hashing'),
                },
              body=[
                  Paragraph(body=RichText('Vantage uses jump consistent hashing [cite:@lamping2014jump] with =V= virtual\nnodes per physical node (default: =V = 150=).\n')),
                  BlankLine(),
                  Paragraph(body=RichText('The ring is rebalanced whenever a node joins or leaves. During rebalance:\n')),
                  BlankLine(),
                  List(
                    items=[
                        ListItem(bullet='-', first_line=RichText('New key assignments are computed atomically.')),
                        ListItem(bullet='-', first_line=RichText('In-flight requests to old shard owners complete normally.')),
                        ListItem(bullet='-', first_line=RichText('Key migration runs in the background at a configurable rate.')),
                      ],
                  ),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Replication Model'),
              properties={
                  'CUSTOM_ID': RichText('replication'),
                },
              body=[
                  Paragraph(body=RichText('Each shard is replicated to =R= peers (default: =R = 2=) using asynchronous\nmulti-master replication. Conflict resolution is /last-write-wins/ based on\na Hybrid Logical Clock (HLC)[fn:hlc].\n')),
                  BlankLine(),
                  Paragraph(body=RichText('[fn:hlc] Kulkarni, S., Demirbas, M., et al. (2014). Logical physical clocks and\nconsistent snapshots in globally distributed databases. /OPODIS 2014/.\n')),
                  BlankLine(),
                ],
              children=[
                  Heading(
                    level=3,
                    title=RichText('Replication lag monitoring'),
                    body=[
                        Drawer(
                          name='NOTE',
                          body=[
                              Paragraph(body=RichText('Replication lag is exposed as a Prometheus gauge =vantage_replication_lag_seconds=.\nAlert threshold: 500 ms sustained for > 60 s → PagerDuty P2.\n')),
                            ],
                        ),
                        BlankLine(),
                      ],
                  ),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Eviction Policies'),
              properties={
                  'CUSTOM_ID': RichText('eviction'),
                },
              body=[
                  Table(
                    rows=[
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' Policy       ')),
                              TableCell(value=RichText(' Algorithm                    ')),
                              TableCell(value=RichText(' Use case                         ')),
                            ],
                        ),
                        TableRuleRow(raw='|--------------+------------------------------+----------------------------------|'),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' ~lru~        ')),
                              TableCell(value=RichText(' Approximated LRU (samples=5) ')),
                              TableCell(value=RichText(' General-purpose                  ')),
                            ],
                        ),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' ~lfu~        ')),
                              TableCell(value=RichText(' Count-min sketch, decay=0.5  ')),
                              TableCell(value=RichText(' Skewed access distributions      ')),
                            ],
                        ),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' ~ttl~        ')),
                              TableCell(value=RichText(' Expires-bucket sorted set    ')),
                              TableCell(value=RichText(' Time-bounded session caches      ')),
                            ],
                        ),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' ~clock~      ')),
                              TableCell(value=RichText(' Two-handed CLOCK algorithm   ')),
                              TableCell(value=RichText(' Low-overhead, uniform workloads  ')),
                            ],
                        ),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' ~noeviction~ ')),
                              TableCell(value=RichText(' Return error when full       ')),
                              TableCell(value=RichText(' Strict capacity guarantees       ')),
                            ],
                        ),
                        TableRow(
                          cells=[
                              TableCell(value=RichText(' ~allkeys-lru~')),
                              TableCell(value=RichText(' LRU across all keys          ')),
                              TableCell(value=RichText(' When all keys may be evicted     ')),
                            ],
                        ),
                      ],
                  ),
                  BlankLine(),
                ],
            ),
            Heading(
              level=2,
              title=RichText('Persistence'),
              properties={
                  'CUSTOM_ID': RichText('persistence'),
                },
              body=[
                  BlankLine(),
                ],
              children=[
                  Heading(
                    level=3,
                    title=RichText('Append-Only File (AOF)'),
                    body=[
                        BlankLine(),
                        Paragraph(body=RichText('The AOF records every write command in RESP3 format, one command per line.\nOn restart, the server replays the AOF to reconstruct state.\n')),
                        BlankLine(),
                        Paragraph(body=RichText('AOF configuration options:\n')),
                        BlankLine(),
                        List(
                          items=[
                              ListItem(bullet='-', first_line=RichText('~aof_enabled~: =true= / =false= (default =false=).')),
                              ListItem(bullet='-', first_line=RichText('~aof_path~: filesystem path (default =/var/lib/vantage/vantage.aof=).')),
                              ListItem(bullet='-', first_line=RichText('~aof_fsync~: =always= / =everysec= / =no= (default =everysec=).')),
                              ListItem(bullet='-', first_line=RichText('~aof_rewrite_min_size~: minimum AOF size before compaction (default =64MiB=).')),
                            ],
                        ),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('Snapshots (RDB-style)'),
                    body=[
                        Paragraph(body=RichText('Point-in-time snapshots are written by forking the process and serialising\nthe keyspace to a compact binary format. Snapshot schedule is configured via\n=snapshot_schedule= as a cron-like expression.\n')),
                        BlankLine(),
                      ],
                  ),
                ],
            ),
            Heading(
