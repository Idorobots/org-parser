              body=[
                  BlankLine(),
                ],
              children=[
                  Heading(
                    level=3,
                    title=RichText('ZADD'),
                    properties={
                        'CUSTOM_ID': RichText('cmd-zadd'),
                      },
                    body=[
                        BlankLine(),
                        ExampleBlock(body='ZADD key [NX|XX] [GT|LT] [CH] [INCR] score member [score member ...]\n'),
                        BlankLine(),
                        Paragraph(body=RichText('Add members with scores to a sorted set.\n')),
                        BlankLine(),
                        List(
                          items=[
                              ListItem(bullet='-', first_line=RichText('~GT~ — only update if new score is *greater* than current.')),
                              ListItem(bullet='-', first_line=RichText('~LT~ — only update if new score is *less* than current.')),
                              ListItem(bullet='-', first_line=RichText('~CH~ — return count of /changes/ (adds + updates) instead of only adds.')),
                            ],
                        ),
                        BlankLine(),
                      ],
