                  Heading(
                    level=3,
                    title=RichText('HINCRBY / HINCRBYFLOAT'),
                    body=[
                        Paragraph(body=RichText('Increment hash field values atomically — identical semantics to ~INCR~/~INCRBYFLOAT~.\n')),
                        BlankLine(),
                      ],
