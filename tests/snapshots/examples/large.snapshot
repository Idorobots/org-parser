                                    TableCell(value=RichText(' < 5.0 ms ')),
                                    TableCell(value=RichText(' 3.21 ms           ')),
                                  ],
                              ),
                            ],
                        ),
                        BlankLine(),
                        Paragraph(body=RichText('Conditions: 3-node cluster, 100 concurrent clients, 1 KiB values, 80/20 read/write.\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('NFR-02: Throughput'),
                    body=[
                        Paragraph(body=RichText('Target: ≥ 500,000 operations/second per node on standard hardware\n(AWS c6i.2xlarge or equivalent: 8 vCPU, 16 GiB RAM).\n')),
                        BlankLine(),
                        Paragraph(body=RichText('Current measured: 620,000 ops/sec (v0.9.4, read-heavy workload).\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('NFR-03: Memory Overhead'),
                    body=[
                        Paragraph(body=RichText('Memory overhead per key (excluding value size) must not exceed 128 bytes.\nCurrent overhead: 84 bytes (slab metadata + hash table entry).\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('NFR-04: Availability'),
                    body=[
                        Paragraph(body=RichText('Target: 99.99% uptime (< 52.6 minutes downtime/year).\nAchieved via: replica failover ≤ 5 seconds, health-check interval 1 second.\n')),
                        BlankLine(),
                        HorizontalRule(rule='-----'),
                        BlankLine(),
                      ],
                  ),
                ],
            ),
          ],
