                    body=[
                        BlankLine(),
                        Paragraph(body=RichText('All connections (client-to-server and inter-node) use TLS 1.3 with mandatory\nmutual authentication. Certificates must be signed by the cluster CA.\n')),
                        BlankLine(),
                        FixedWidthBlock(body='[tls]\nca_cert = "/etc/vantage/ca.crt"\nserver_cert = "/etc/vantage/server.crt"\nserver_key = "/etc/vantage/server.key"\nrequire_client_cert = true\nmin_version = "TLSv1.3"'),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('Access Control Lists'),
                    body=[
                        Paragraph(body=RichText('ACL rules are evaluated in order; first match wins. Rule syntax:\n')),
                        BlankLine(),
                        FixedWidthBlock(body='user alice on >password ~cache:* &* +@read +@write -DEBUG\nuser readonly on >secret ~*  &* +@read\nuser default off'),
                        BlankLine(),
                        HorizontalRule(rule='-----'),
                        BlankLine(),
