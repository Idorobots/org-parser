      Heading(
        level=1,
        title=RichText('API Reference'),
        properties={
            'CUSTOM_ID': RichText('api-reference'),
          },
        body=[
            BlankLine(),
          ],
        children=[
            Heading(
              level=2,
              title=RichText('String Commands'),
              properties={
                  'CUSTOM_ID': RichText('string-commands'),
                },
              body=[
                  BlankLine(),
                ],
              children=[
                  Heading(
                    level=3,
                    title=RichText('GET'),
                    properties={
                        'CUSTOM_ID': RichText('cmd-get'),
                      },
                    body=[
                        BlankLine(),
                        ExampleBlock(body='GET key\n'),
                        BlankLine(),
                        Paragraph(body=RichText('Return the value associated with =key=, or nil if the key does not exist.\nTime complexity: O(1). Returns an error if the value is not a string.\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('SET'),
                    properties={
                        'CUSTOM_ID': RichText('cmd-set'),
                      },
                    body=[
                        ExampleBlock(body='SET key value [NX | XX] [GET] [EX seconds | PX ms | EXAT ts | PXAT ts | KEEPTTL]\n'),
                        BlankLine(),
                        Paragraph(body=RichText('Set =key= to =value=. Options:\n')),
                        BlankLine(),
                        List(
                          items=[
                              ListItem(bullet='-', first_line=RichText('~NX~ — only set if key does *not* exist.')),
                              ListItem(bullet='-', first_line=RichText('~XX~ — only set if key *already* exists.')),
                              ListItem(bullet='-', first_line=RichText('~GET~ — return the old value before overwriting.')),
                              ListItem(bullet='-', first_line=RichText('~KEEPTTL~ — preserve existing TTL when overwriting.')),
                            ],
                        ),
                        BlankLine(),
                        Paragraph(body=RichText('Time complexity: O(1).\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('MGET / MSET'),
                    properties={
                        'CUSTOM_ID': RichText('cmd-mget-mset'),
                      },
                    body=[
                        ExampleBlock(body='MGET key [key ...]\nMSET key value [key value ...]\n'),
                        BlankLine(),
                        Paragraph(body=RichText('Atomic multi-key read and write. ~MSET~ is always successful. ~MSETNX~\n(set multiple only if none exist) is also supported.\nTime complexity: O(N) where N is the number of keys.\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('INCR / INCRBY / DECR / DECRBY'),
                    properties={
                        'CUSTOM_ID': RichText('cmd-incr'),
                      },
                    body=[
                        Paragraph(body=RichText('Increment or decrement integer-valued strings atomically.\n')),
                        BlankLine(),
                        SourceBlock(body='INCR counter         → integer reply\nINCRBY counter 5     → integer reply\nINCRBYFLOAT rate 0.1 → bulk string reply (float as string)\n'),
                        BlankLine(),
                      ],
                  ),
                ],
            ),
            Heading(
              level=2,
              title=RichText('List Commands'),
              properties={
                  'CUSTOM_ID': RichText('list-commands'),
                },
              body=[
                  BlankLine(),
                ],
              children=[
                  Heading(
                    level=3,
                    title=RichText('LPUSH / RPUSH'),
                    properties={
                        'CUSTOM_ID': RichText('cmd-lpush'),
                      },
                    body=[
                        BlankLine(),
                        ExampleBlock(body='LPUSH key element [element ...]\nRPUSH key element [element ...]\n'),
                        BlankLine(),
                        Paragraph(body=RichText('Push elements to the head (=L=) or tail (=R=) of a list.\nMultiple elements are pushed in order: ~LPUSH mylist a b c~ results in =c b a= (c at head).\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('LRANGE'),
                    properties={
                        'CUSTOM_ID': RichText('cmd-lrange'),
                      },
                    body=[
                        ExampleBlock(body='LRANGE key start stop\n'),
                        BlankLine(),
                        Paragraph(body=RichText('Return a range of elements. Indices are 0-based; negative indices count from the tail\n(=-1= is the last element). O(S+N) where S is the offset from head/tail and N is range size.\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('LMOVE'),
                    properties={
                        'CUSTOM_ID': RichText('cmd-lmove'),
                      },
                    body=[
                        ExampleBlock(body='LMOVE source destination LEFT|RIGHT LEFT|RIGHT\n'),
                        BlankLine(),
                        Paragraph(body=RichText('Atomically move an element from one list to another. Replaces the deprecated ~RPOPLPUSH~.\n')),
                        BlankLine(),
                      ],
                  ),
                ],
