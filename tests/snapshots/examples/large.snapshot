                        List(
                          items=[
                              ListItem(bullet='-', checkbox='X', first_line=RichText('String (binary-safe, up to 512 MiB)')),
                              ListItem(bullet='-', checkbox='X', first_line=RichText('List (doubly linked list or compressed quicklist)')),
                              ListItem(bullet='-', checkbox='X', first_line=RichText('Hash (hash table with listpack encoding for small hashes)')),
                              ListItem(bullet='-', checkbox='X', first_line=RichText('Set (hash table with intset encoding for small integer sets)')),
                              ListItem(bullet='-', checkbox='X', first_line=RichText('Sorted Set (skip list + hash table, listpack for small zsets)')),
                              ListItem(bullet='-', checkbox='-', first_line=RichText('Stream (in progress — targeting v1.2)')),
                              ListItem(bullet='-', checkbox=' ', first_line=RichText('JSON (planned for v2.0 — requires RFC 8259 compliance)')),
                              ListItem(bullet='-', checkbox=' ', first_line=RichText('Bloom Filter (planned, via probabilistic module)')),
