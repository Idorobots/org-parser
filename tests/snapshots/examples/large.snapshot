                  BlankLine(),
                ],
              children=[
                  Heading(
                    level=3,
                    title=RichText('NFR-01: Latency'),
                    properties={
                        'CUSTOM_ID': RichText('nfr-latency'),
                      },
                    body=[
                        BlankLine(),
                        Table(
                          rows=[
                              TableRow(
                                cells=[
                                    TableCell(value=RichText(' Percentile ')),
                                    TableCell(value=RichText(' Target   ')),
                                    TableCell(value=RichText(' Measured (v0.9.4) ')),
                                  ],
                              ),
                              TableRuleRow(raw='|------------+----------+-------------------|'),
                              TableRow(
                                cells=[
                                    TableCell(value=RichText(' p50        ')),
                                    TableCell(value=RichText(' < 0.1 ms ')),
                                    TableCell(value=RichText(' 0.08 ms           ')),
                                  ],
                              ),
                              TableRow(
                                cells=[
