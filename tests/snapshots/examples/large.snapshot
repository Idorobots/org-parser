                    title=RichText('FR-02: Key Expiry'),
                    body=[
                        List(
                          items=[
                              ListItem(bullet='-', checkbox='X', first_line=RichText('=EX seconds= — expire after N seconds.')),
                              ListItem(bullet='-', checkbox='X', first_line=RichText('=PX milliseconds= — expire after N milliseconds.')),
                              ListItem(bullet='-', checkbox='X', first_line=RichText('=EXAT unix-timestamp= — expire at Unix timestamp (seconds).')),
                              ListItem(bullet='-', checkbox='X', first_line=RichText('=PXAT unix-timestamp-ms= — expire at Unix timestamp (milliseconds).')),
                              ListItem(bullet='-', checkbox='X', first_line=RichText('=PERSIST= — remove expiry from a key.')),
                              ListItem(bullet='-', checkbox='X', first_line=RichText('=TTL key= — return remaining seconds.')),
                              ListItem(bullet='-', checkbox='X', first_line=RichText('=PTTL key= — return remaining milliseconds.')),
