            Heading(
              level=2,
              title=RichText('Architectural Decision Records'),
              properties={
                  'CUSTOM_ID': RichText('adrs'),
                },
              body=[
                  Paragraph(body=RichText('ADRs document significant architectural decisions. They are stored in =docs/adr/=.\n')),
                  BlankLine(),
                ],
              children=[
                  Heading(
                    level=3,
                    title=RichText('ADR-001: Adopt jump consistent hashing'),
                    properties={
                        'CUSTOM_ID': RichText('adr-001'),
                      },
                    body=[
                        Paragraph(body=RichText('CLOSED: [2024-03-15 Fri]\n')),
                        BlankLine(),
                        Paragraph(body=RichText('*Status:* Accepted.\n*Decision:* Use jump consistent hashing over rendezvous hashing.\n*Rationale:* Lower variance in key distribution; faster computation; well-studied\nguarantees. Trade-off: less flexibility in heterogeneous node weights.\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('ADR-002: RESP3 as default client protocol'),
                    properties={
                        'CUSTOM_ID': RichText('adr-002'),
                      },
                    body=[
                        Paragraph(body=RichText('CLOSED: [2024-04-02 Tue]\n')),
                        BlankLine(),
                        Paragraph(body=RichText('*Status:* Accepted.\n*Decision:* Default new clients to RESP3; maintain RESP2 compatibility.\n*Rationale:* RESP3 supports typed responses (maps, sets) natively, reducing\nclient-side parsing overhead. Existing Redis clients continue to work unchanged.\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('ADR-003: Tokio over async-std as the async runtime'),
                    properties={
                        'CUSTOM_ID': RichText('adr-003'),
                      },
                    body=[
                        Paragraph(body=RichText('CLOSED: [2024-04-10 Wed]\n')),
                        BlankLine(),
                        Paragraph(body=RichText("*Status:* Accepted.\n*Decision:* Use Tokio as the sole async runtime.\n*Rationale:* Tokio has the largest ecosystem (tower, hyper, axum, tonic).\nThe work-stealing scheduler fits our use case better than async-std's\nsingle-threaded per-thread-per-core model.\n")),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('ADR-004: LWW conflict resolution using Hybrid Logical Clocks'),
                    properties={
                        'CUSTOM_ID': RichText('adr-004'),
                      },
                    body=[
                        Paragraph(body=RichText('CLOSED: [2024-05-20 Mon]\n')),
                        BlankLine(),
                        Paragraph(body=RichText('*Status:* Accepted.\n*Decision:* Use HLC timestamps for LWW conflict resolution instead of wall-clock time.\n*Rationale:* Wall-clock LWW suffers from clock skew across nodes. HLC guarantees\nthat =HLC(a) < HLC(b)= whenever event =a= causally precedes event =b=, even with\nmodest clock drift (< 500 ms). See [cite:@kulkarni2014hlc].\n')),
                        BlankLine(),
                      ],
                  ),
                  Heading(
                    level=3,
                    title=RichText('ADR-005: Pluggable eviction via trait objects'),
                    properties={
                        'CUSTOM_ID': RichText('adr-005'),
                      },
                    body=[
                        Paragraph(body=RichText('CLOSED: [2024-07-01 Mon]\n')),
                        BlankLine(),
                        Paragraph(body=RichText('*Status:* Accepted.\n*Decision:* Model eviction policies as ~dyn EvictionPolicy~ trait objects rather\nthan an enum.\n*Rationale:* Allows third-party eviction policies without modifying core code.\nPerformance cost (one virtual dispatch per eviction candidate evaluation) is\nacceptable at < 1 ns overhead per call.\n')),
                        BlankLine(),
                        HorizontalRule(rule='-----'),
                        BlankLine(),
                      ],
                  ),
                ],
            ),
          ],
      ),
