                        ListItem(bullet='.', ordered_counter='3', first_line=RichText('Add or update tests for any changed behaviour.')),
                        ListItem(bullet='.', ordered_counter='4', first_line=RichText('Update =CHANGELOG.md= under the =Unreleased= heading.')),
                        ListItem(bullet='.', ordered_counter='5', first_line=RichText('Open a PR against =main=. A maintainer will review within 5 business days.')),
                        ListItem(bullet='.', ordered_counter='6', first_line=RichText('Two approvals are required before merge.')),
