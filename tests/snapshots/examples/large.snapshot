                    properties={
                        'CUSTOM_ID': RichText('cmd-hset'),
                      },
                    body=[
                        BlankLine(),
                        ExampleBlock(body='HSET key field value [field value ...]\nHGET key field\nHMGET key field [field ...]\nHGETALL key\n'),
