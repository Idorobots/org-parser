Document(
  filename='examples/ordered-list-basic.org',
  category=RichText('ordered-list-basic'),
  children=[
      Heading(
        level=1,
        title=RichText('Ordered Lists'),
        body=[
            BlankLine(),
            Paragraph(body=RichText('Period-terminated digit counter:\n')),
            BlankLine(),
            List(
              items=[
                  ListItem(bullet='.', ordered_counter='1', first_line=RichText('first')),
                  ListItem(bullet='.', ordered_counter='2', first_line=RichText('second')),
                  ListItem(bullet='.', ordered_counter='3', first_line=RichText('third')),
                ],
            ),
            BlankLine(),
            Paragraph(body=RichText('Parenthesis-terminated digit counter:\n')),
            BlankLine(),
            List(
              items=[
                  ListItem(bullet=')', ordered_counter='1', first_line=RichText('one')),
                  ListItem(bullet=')', ordered_counter='2', first_line=RichText('two')),
                  ListItem(bullet=')', ordered_counter='3', first_line=RichText('three')),
                ],
            ),
            BlankLine(),
            Paragraph(body=RichText('Letter counter:\n')),
            BlankLine(),
            List(
              items=[
                  ListItem(bullet='.', ordered_counter='a', first_line=RichText('alpha')),
                  ListItem(bullet='.', ordered_counter='b', first_line=RichText('beta')),
                  ListItem(bullet='.', ordered_counter='c', first_line=RichText('gamma')),
                ],
            ),
            BlankLine(),
            Paragraph(body=RichText('Counter-set (reset to 5):\n')),
            BlankLine(),
            List(
              items=[
                  ListItem(bullet='.', ordered_counter='5', counter_set='5', first_line=RichText('fifth')),
                  ListItem(bullet='.', ordered_counter='6', first_line=RichText('sixth')),
                ],
            ),
          ],
      ),
    ],
